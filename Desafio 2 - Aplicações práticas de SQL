-- Passo 1: Crie um novo Schema com nome DESAFIO

CREATE schema DESAFIO;
USE DESAFIO;


-- Passo 2: Crie duas novas tabelas com pelo menos 4 colunas cada (não esqueça de indicar o Primary Key)

CREATE TABLE Aluno (
	id_Aluno INT PRIMARY KEY AUTO_INCREMENT,
    NomeDoAluno VARCHAR (45) NOT NULL,
    estado VARCHAR (45) NOT NULL,
    idade INT NOT NULL
);

CREATE TABLE Curso (
	id_Curso INT PRIMARY KEY AUTO_INCREMENT,
    NomeDoCurso VARCHAR(45) NOT NULL,
    carga_horaria INT,
    id_Aluno INT,
    FOREIGN KEY (id_Aluno) REFERENCES Aluno(id_Aluno)
);


